// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MessageType {
  TEXT
  POST
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  username  String   @unique @db.VarChar(50)
  email     String   @unique @db.VarChar(255)
  password  String
  bio       String?  @db.VarChar(280)
  avatar    String?  @db.VarChar(2048)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  posts     Post[]
  comments  Comment[]
  likes     Like[]
  messages  Message[]
  followers Follow[] @relation("UserFollowers")
  following Follow[] @relation("UserFollowing")

  @@index([createdAt], map: "idx_users_created_at")
  @@map("users")
}

model Post {
  id        String   @id @default(uuid()) @db.Uuid
  content   String   @db.VarChar(500)
  imageUrl  String?  @db.VarChar(2048)
  authorId  String   @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments Comment[]
  likes    Like[]
  messages Message[]

  @@index([authorId], map: "idx_posts_author_id")
  @@index([createdAt], map: "idx_posts_created_at")
  @@map("posts")
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.VarChar(300)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String   @db.Uuid
  postId    String   @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId], map: "idx_comments_post_id")
  @@index([userId], map: "idx_comments_user_id")
  @@map("comments")
}

model Like {
  id        String   @id @default(cuid())
  userId    String   @db.Uuid
  postId    String   @db.Uuid
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId], map: "uq_likes_user_post")
  @@index([userId], map: "idx_likes_user_id")
  @@index([postId], map: "idx_likes_post_id")
  @@map("likes")
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String   @db.Uuid
  followingId String   @db.Uuid
  createdAt   DateTime @default(now())

  follower  User @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId], map: "uq_follows_follower_following")
  @@index([followerId], map: "idx_follows_follower_id")
  @@index([followingId], map: "idx_follows_following_id")
  @@map("follows")
}

model Conversation {
  id              String   @id @default(uuid()) @db.Uuid
  participants    String[] @db.Uuid
  participantsKey String   @unique @db.VarChar(255)
  lastMessageId   String?  @db.Uuid
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  messages        Message[]

  @@index([updatedAt], map: "idx_conversations_updated_at")
  @@index([participants], type: Gin, map: "idx_conversations_participants_gin")
  @@map("conversations")
}

model Message {
  id             String      @id @default(cuid())
  conversationId String      @db.Uuid
  senderId       String      @db.Uuid
  type           MessageType
  text           String?     @db.VarChar(2000)
  postId         String?     @db.Uuid
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  post         Post?        @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt], map: "idx_messages_conversation_created_at")
  @@index([senderId], map: "idx_messages_sender_id")
  @@index([postId], map: "idx_messages_post_id")
  @@map("messages")
}
